# 目标设备 (小米 4A 千兆版 v1)
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_xiaomi_mi-router-4a-gigabit=y

# 1. 强制开启压缩优化 (关键：决定固件能否装下)
CONFIG_STRIP_KERNEL_EXPORTS=y
CONFIG_USE_MKLIBS=y
CONFIG_COLLECT_KERNEL_DEBUG=n

# 2. 核心科学上网插件：选择 SSR-Plus (最省空间方案)
# 不选 OpenClash 或 PassWall 是因为它们的 Xray/Clash 内核体积太大
CONFIG_PACKAGE_luci-app-ssr-plus=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_Libev_Client=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_ShadowsocksR_Libev_Client=y
# 如果一定要 Xray，只选下面这一个，但注意体积风险
# CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Xray=y

# 3. 彻底删除无用驱动 (4A 硬件不支持的部分)
# 取消 USB 支持 (省约 1.5MB)
# CONFIG_PACKAGE_kmod-usb-core is not set
# CONFIG_PACKAGE_kmod-usb-ohci is not set
# CONFIG_PACKAGE_kmod-usb2 is not set
# CONFIG_PACKAGE_kmod-usb3 is not set

# 取消存储与文件系统 (省约 1MB)
# CONFIG_PACKAGE_kmod-fs-autofs4 is not set
# CONFIG_PACKAGE_kmod-fs-msdos is not set
# CONFIG_PACKAGE_kmod-fs-ntfs is not set

# 4. 界面与语言优化
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-theme-argon=y
# 取消其他多余主题
# CONFIG_PACKAGE_luci-theme-bootstrap is not set
# CONFIG_PACKAGE_luci-theme-material is not set

# 5. 取消 Docker 与大内存应用 (4A 无法运行)
# CONFIG_PACKAGE_luci-app-docker is not set
# CONFIG_PACKAGE_luci-app-dockerman is not set
