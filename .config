# 目标设备设置 (小米 4A 千兆版)
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_xiaomi_mi-router-4a-gigabit=y

# 基础优化：开启 UPX 压缩以节省闪存空间
CONFIG_STRIP_KERNEL_EXPORTS=y
CONFIG_USE_MKLIBS=y

# 核心插件：PassWall (比 OpenClash 更轻量)
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-passwall_Iptables_Transparent_Proxy=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Libev_Client=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_ShadowsocksR_Libev_Client=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray=y
# 取消一些不常用的协议内核以减小体积
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Trojan-Plus is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray-Geodata is not set

# 界面与语言
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-theme-argon=y

# --- 必须瘦身的部分 ---
# 取消 USB 相关（4A 没接口，能省约 1.5MB）
# CONFIG_PACKAGE_kmod-usb-core is not set
# CONFIG_PACKAGE_kmod-usb-ohci is not set
# CONFIG_PACKAGE_kmod-usb2 is not set
# CONFIG_PACKAGE_kmod-usb3 is not set

# 取消 Docker 相关 (4A 跑不动，能省约 3MB)
# CONFIG_PACKAGE_luci-app-docker is not set
# CONFIG_PACKAGE_docker-ce is not set

# 取消多余的 Luci 插件 (只保留核心网络功能)
# CONFIG_PACKAGE_luci-app-wol is not set
# CONFIG_PACKAGE_luci-app-vsftpd is not set
